---
const { theme, delay = '' } = Astro.props;
---
<article class={`reveal ${delay} group theme-card bg-cream-card border-[2.5px] border-[rgba(24,20,38,.16)] rounded-[18px] overflow-hidden flex flex-col`}>
  <a href={theme.demo} class="relative block aspect-[3/4] overflow-hidden bg-dark-2" aria-label={`View the ${theme.name} demo`}>
    <img src={`/shots/${theme.slug}.jpg`} alt={`${theme.name} theme preview`} loading="lazy" class="shot-img w-full h-full object-cover" />
    <span class="shot-hint absolute bottom-3 right-3 z-[2] flex items-center gap-1 bg-ink/80 text-cream text-[.58rem] font-semibold uppercase tracking-[.12em] px-2 py-1 rounded-full backdrop-blur-sm">
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
      Scroll
    </span>
    {theme.tag && (
      <span class="absolute top-3 left-3 bg-purple text-ink text-[.62rem] font-bold uppercase tracking-[.1em] px-2 py-1 rounded-md" style="box-shadow:2px 2px 0 var(--color-ink)">{theme.tag}</span>
    )}
  </a>
  <div class="p-[1.15rem] pb-5 flex flex-col flex-1 text-ink">
    <h3 class="font-display text-[1.4rem] uppercase flex justify-between items-baseline gap-2">
      {theme.name}
      <span class={`font-body font-bold text-[.95rem] ${theme.free ? 'text-[#2fa36b]' : 'text-purple-deep'}`}>{theme.price}</span>
    </h3>
    <div class="flex flex-wrap gap-1.5 mt-2.5">
      {theme.genre.split('·').map((g) => <span class="vibe-chip">{g.trim()}</span>)}
    </div>
    <p class="text-[#5e576b] text-[.9rem] mt-3 mb-[1.15rem] flex-1">{theme.blurb}</p>
    <div class="flex gap-2">
      <a href={theme.demo} class="btn btn-line btn-sm flex-1 justify-center">View demo</a>
      <a href={theme.buy} class="btn btn-ink btn-sm flex-1 justify-center">{theme.free ? 'Get it free' : 'Get it'}</a>
    </div>
  </div>
</article>
