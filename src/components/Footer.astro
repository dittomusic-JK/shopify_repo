---
---
<footer id="contact" class="bg-[#110e18] pt-12 pb-8 border-t border-white/10 relative z-[2]">
  <div class="max-w-[1180px] mx-auto px-5 sm:px-10">
    <div class="grid gap-8 md:grid-cols-[1.6fr_1fr_1fr_1.6fr]">
      <div>
        <a href="/" class="inline-flex"><img src="/logo_light.webp" alt="Riffride" class="h-[60px] w-auto" /></a>
        <p class="text-muted text-[.9rem] mt-4 max-w-[30ch]">Shopify themes built for artists &amp; musicians. The quick path to selling merch.</p>
      </div>
      <div>
        <h5 class="font-display text-[.85rem] tracking-[.08em] uppercase text-cream mb-3">Links</h5>
        <a href="/#templates" class="block text-muted text-[.9rem] mb-2 hover:text-purple transition">Templates</a>
        <a href="/#about" class="block text-muted text-[.9rem] mb-2 hover:text-purple transition">About</a>
        <a href="/#faq" class="block text-muted text-[.9rem] mb-2 hover:text-purple transition">FAQ</a>
        <a href="/#contact" class="block text-muted text-[.9rem] mb-2 hover:text-purple transition">Contact</a>
      </div>
      <div>
        <h5 class="font-display text-[.85rem] tracking-[.08em] uppercase text-cream mb-3">Info</h5>
        <a href="/#templates" class="block text-muted text-[.9rem] mb-2 hover:text-purple transition">Get the free theme</a>
        <a href="#" class="block text-muted text-[.9rem] mb-2 hover:text-purple transition">License</a>
        <a href="#" class="block text-muted text-[.9rem] mb-2 hover:text-purple transition">Support</a>
        <a href="#" class="block text-muted text-[.9rem] mb-2 hover:text-purple transition">Terms</a>
      </div>
      <div>
        <h5 class="font-display text-[.85rem] tracking-[.08em] uppercase text-cream mb-3">Join the crew</h5>
        <p class="text-muted text-[.9rem] mb-3">New themes, drops and tips for selling your music. No spam.</p>
        <form class="flex gap-2" onsubmit="return false">
          <input type="email" placeholder="your@email.com" aria-label="Email" class="flex-1 min-w-0 bg-dark-2 border-2 border-white/10 rounded-full px-4 py-2.5 text-cream placeholder:text-muted" />
          <button class="btn btn-purple" type="submit">Join</button>
        </form>
        <div class="flex gap-3 mt-4">
          <a href="#" class="social" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
          <a href="#" class="social" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 3c.3 2.2 1.7 3.8 4 4v2.6c-1.5 0-2.9-.5-4-1.3V15a5.5 5.5 0 1 1-5.5-5.5c.3 0 .6 0 .9.1v2.7a2.8 2.8 0 1 0 2 2.7V3H14z"/></svg></a>
          <a href="#" class="social" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.7-1.7C19.3 5.2 12 5.2 12 5.2s-7.3 0-8.9.4A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.7 1.7c1.6.4 8.9.4 8.9.4s7.3 0 8.9-.4a2.5 2.5 0 0 0 1.7-1.7C23 15.2 23 12 23 12zM9.8 15.3V8.7l5.7 3.3z"/></svg></a>
          <a href="#" class="social" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h3l-7 8 8 12h-6l-5-7-6 7H2l8-9L2 2h6l4 6z"/></svg></a>
        </div>
      </div>
    </div>
    <div class="mt-10 pt-6 border-t border-white/10 flex justify-between flex-wrap gap-2 text-muted text-[.8rem]">
      <span>© 2026 Riffride. Made for artists &amp; musicians.</span>
      <span>Themes run on Shopify. From ~$5/mo.</span>
    </div>
  </div>
</footer>
