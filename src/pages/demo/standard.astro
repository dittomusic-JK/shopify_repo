---
import DemoLayout from '../../layouts/DemoLayout.astro';
import { themes } from '../../data/themes.js';
const theme = themes.find((t) => t.slug === 'standard');
const fonts = 'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Dancing+Script:wght@600;700&family=Caveat:wght@400;500;600&display=swap';

const tracks = [
  { n: '01', name: 'Northern Lights', t: '3:10' },
  { n: '02', name: 'Slow River', t: '4:02' },
  { n: '03', name: 'November Girl', t: '3:48' },
  { n: '04', name: 'Salt and Rust', t: '5:10' },
  { n: '05', name: 'The Long Way', t: '4:36' },
];
const tour = [
  { date: 'Apr 10, 2026', city: 'Nashville, TN', venue: 'The Basement East', soldout: false },
  { date: 'Apr 17, 2026', city: 'Chicago, IL', venue: "Schubas Tavern", soldout: true },
  { date: 'Apr 24, 2026', city: 'New York, NY', venue: 'Rockwood Music Hall', soldout: false },
  { date: 'May 02, 2026', city: 'London, UK', venue: 'Union Chapel', soldout: false },
  { date: 'May 09, 2026', city: 'Amsterdam, NL', venue: 'Paradiso', soldout: false },
];
const merch = [
  { name: 'Northern Lights — Vinyl', img: 'vinyl.jpg' },
  { name: 'Embroidered Hoodie', img: 'hoodie.jpg' },
  { name: 'Northern Lights Tee', img: 'tee.jpg' },
];
---
<DemoLayout theme={theme} fonts={fonts} title="Alder & Vale — Riffride Standard demo">
  <div class="st-page">
    <header class="st-head">
      <a class="st-logo" href="#">Alder &amp; Vale</a>
      <nav class="st-nav"><a href="#music">Music</a><a href="#tour">Tour</a><a href="#merch">Merch</a><a href="#watch">Videos</a><a href="#contact">Contact</a></nav>
      <div class="st-soc">
        <a href="https://spotify.com" target="_blank" rel="noopener" aria-label="Spotify"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.6 14.4a.75.75 0 01-1 .25c-2.7-1.6-6.1-2-10.1-1.1a.75.75 0 11-.3-1.45c4.3-1 8.1-.5 11.1 1.3.36.22.47.69.3 1zm1.2-2.7a.94.94 0 01-1.3.3c-3-1.85-7.6-2.4-11.2-1.3a.94.94 0 11-.55-1.8c4.1-1.25 9.2-.65 12.7 1.5.44.27.58.85.35 1.3zm.1-2.8C14.6 8.1 8.9 7.9 5.6 8.9a1.12 1.12 0 11-.65-2.15c3.8-1.15 10.1-.9 14 1.4a1.12 1.12 0 01-1.15 1.95z"/></svg></a>
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
        <a href="https://tiktok.com" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 3c.3 2.2 1.7 3.8 4 4v2.6c-1.5 0-2.9-.5-4-1.3V15a5.5 5.5 0 1 1-5.5-5.5c.3 0 .6 0 .9.1v2.7a2.8 2.8 0 1 0 2 2.7V3H14z"/></svg></a>
      </div>
    </header>

    <!-- hero -->
    <section class="st-hero" id="music">
      <img class="st-hero__bg" src="/demo/standard/hero.jpg" alt="" />
      <div class="st-hero__scrim"></div>
      <div class="st-hero__inner">
        <h1 class="st-hero__name">Alder &amp; Vale</h1>
        <p class="st-hero__sub">Northern Lights — New Single</p>
        <a class="st-btn st-btn--blue" href="#listen">Listen now</a>
      </div>
    </section>

    <!-- latest release + tracklist -->
    <section class="st-release" id="listen">
      <div class="st-wrap st-release__grid">
        <div class="st-release__art"><img src="/demo/standard/album.jpg" alt="Northern Lights" loading="lazy" /></div>
        <div class="st-release__body">
          <p class="st-kicker">The album</p>
          <h2 class="st-h2">Northern Lights</h2>
          <p class="st-script-text">A deeply personal collection of ten songs written across three years of travel. Recorded live to tape in a farmhouse in Vermont. Raw, honest, and gently devastating.</p>
          <ul class="st-tracks">
            {tracks.map((tr) => (
              <li class="st-track"><span class="st-track__n">{tr.n}</span><span class="st-track__name">{tr.name}</span><span class="st-track__t">{tr.t}</span><span class="st-track__play">▶</span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- tour -->
    <section class="st-tour" id="tour">
      <div class="st-wrap">
        <span class="st-dash"></span>
        <h2 class="st-h2 st-h2--big">Tour dates</h2>
        <ul class="st-tour__list">
          <li class="st-tour__head"><span>Date</span><span>City</span><span>Venue</span><span></span></li>
          {tour.map((d) => (
            <li class="st-tour__row">
              <span class="st-tour__date">{d.date}</span><span class="st-tour__city">{d.city}</span><span class="st-tour__venue">{d.venue}</span>
              {d.soldout ? <span class="st-tour__out">Sold out</span> : <a class="st-btn st-btn--blue st-btn--sm" href="#">Tickets</a>}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- merch -->
    <section class="st-merch" id="merch">
      <div class="st-wrap">
        <span class="st-dash"></span>
        <h2 class="st-h2 st-h2--big">Merch</h2>
        <div class="st-merch__grid">
          {merch.map((m) => (
            <article class="st-merch__item">
              <div class="st-merch__imgwrap"><img src={`/demo/standard/${m.img}`} alt={m.name} loading="lazy" /><span class="st-soldout">Sold out</span></div>
            </article>
          ))}
        </div>
        <div class="st-center"><a class="st-btn st-btn--blue" href="#">Shop all merch</a></div>
      </div>
    </section>

    <!-- watch -->
    <section class="st-watch" id="watch">
      <div class="st-wrap">
        <span class="st-dash"></span>
        <h2 class="st-h2 st-h2--big">Watch</h2>
        <p class="st-script-text st-watch__sub">Wandering Home — Live at Union Chapel</p>
        <div class="st-video"><span class="st-video__play">▶</span></div>
      </div>
    </section>

    <!-- stay in touch -->
    <section class="st-touch" id="contact">
      <div class="st-wrap">
        <span class="st-dash"></span>
        <h2 class="st-h2 st-h2--big">Stay in Touch</h2>
        <p class="st-script-text">New songs, tour dates, and stories from the road. No spam, ever.</p>
        <p class="st-kicker st-touch__listen">Listen</p>
        <div class="st-touch__links">
          <a class="st-stream" href="https://spotify.com" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.6 14.4a.75.75 0 01-1 .25c-2.7-1.6-6.1-2-10.1-1.1a.75.75 0 11-.3-1.45c4.3-1 8.1-.5 11.1 1.3.36.22.47.69.3 1zm1.2-2.7a.94.94 0 01-1.3.3c-3-1.85-7.6-2.4-11.2-1.3a.94.94 0 11-.55-1.8c4.1-1.25 9.2-.65 12.7 1.5.44.27.58.85.35 1.3zm.1-2.8C14.6 8.1 8.9 7.9 5.6 8.9a1.12 1.12 0 11-.65-2.15c3.8-1.15 10.1-.9 14 1.4a1.12 1.12 0 01-1.15 1.95z"/></svg>Spotify</a>
          <a class="st-stream" href="https://soundcloud.com" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M1 14a1 1 0 012 0v3a1 1 0 01-2 0zm3-2a1 1 0 012 0v5a1 1 0 01-2 0zm3-1a1 1 0 012 0v6a1 1 0 01-2 0zm3-2a1 1 0 012 0v8a1 1 0 01-2 0zm4-2c.4 0 .8.1 1.1.3A4 4 0 0123 11h.5a3.5 3.5 0 010 7H14a1 1 0 01-1-1V8a1 1 0 011-1z"/></svg>SoundCloud</a>
        </div>
      </div>
    </section>

    <!-- discography -->
    <section class="st-disco">
      <div class="st-wrap">
        <span class="st-dash"></span>
        <h2 class="st-h2 st-h2--big">Discography</h2>
        <div class="st-disco__grid">
          <article class="st-disco__item"><img src="/demo/standard/album.jpg" alt="Northern Lights" loading="lazy" /><h3>Northern Lights</h3></article>
          <article class="st-disco__item"><img src="/demo/standard/album2.jpg" alt="Halfway Home" loading="lazy" /><h3>Halfway Home</h3></article>
        </div>
      </div>
    </section>

    <footer class="st-foot">
      <p>© 2026 · Alder &amp; Vale</p>
      <p class="st-credit">Created with <a href="/">Riffride</a></p>
    </footer>
  </div>
</DemoLayout>

<style>
  .st-page{position:relative;background:#0c0c0d;color:#ece9e3;font-family:'Caveat','Segoe Print',cursive}
  .st-wrap{max-width:1240px;margin:0 auto;padding:0 clamp(1.5rem,5vw,4rem)}
  .st-h2{font-family:'Playfair Display',serif;font-weight:600;color:#ece9e3;line-height:1.05}
  .st-h2--big{font-size:clamp(2.6rem,6vw,4.5rem);margin-bottom:2rem}
  .st-kicker{font-family:'Caveat',cursive;text-transform:uppercase;letter-spacing:.14em;font-size:1.05rem;color:#7e8a99}
  .st-script-text{font-family:'Caveat',cursive;font-size:1.4rem;line-height:1.5;color:#b9b6ad}
  .st-dash{display:block;width:42px;height:2px;background:#5e8cb5;margin-bottom:1.4rem}
  .st-center{text-align:center;margin-top:2.5rem}
  .st-btn{font-family:'Caveat',cursive;display:inline-flex;align-items:center;font-size:1.15rem;letter-spacing:.06em;text-transform:uppercase;padding:.6rem 1.7rem;border-radius:4px;transition:.2s;cursor:pointer}
  .st-btn--blue{background:#3f6b8f;color:#f3f1ea}
  .st-btn--blue:hover{background:#4a7ba3}
  .st-btn--sm{font-size:.95rem;padding:.4rem 1.2rem}

  /* header */
  .st-head{position:absolute;top:0;left:0;right:0;z-index:20;display:flex;align-items:center;justify-content:space-between;max-width:1400px;margin:0 auto;padding:1.4rem clamp(1.5rem,5vw,4rem)}
  .st-logo{font-family:'Dancing Script',cursive;font-weight:700;font-size:2rem;color:#fff}
  .st-nav{display:flex;gap:1.8rem}
  .st-nav a{font-family:'Caveat',cursive;text-transform:uppercase;letter-spacing:.1em;font-size:1.05rem;color:#fff;opacity:.85;transition:.2s}
  .st-nav a:hover{opacity:1;color:#8fb4d6}
  .st-soc{display:flex;gap:.6rem}
  .st-soc a{width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;color:#fff;transition:.2s}
  .st-soc a:hover{background:#3f6b8f}
  .st-soc svg{width:15px;height:15px}

  /* hero */
  .st-hero{position:relative;min-height:92vh;display:grid;place-items:center;text-align:center;overflow:hidden}
  .st-hero__bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top}
  .st-hero__scrim{position:absolute;inset:0;background:linear-gradient(180deg,rgba(12,12,13,.35),rgba(12,12,13,.65))}
  .st-hero__inner{position:relative;z-index:2;padding:2rem}
  .st-hero__name{font-family:'Playfair Display',serif;font-weight:600;font-size:clamp(2.8rem,8vw,5.5rem);color:#fff;text-shadow:0 2px 30px rgba(0,0,0,.5)}
  .st-hero__sub{font-family:'Caveat',cursive;font-size:1.6rem;color:#e6e3da;margin:.4rem 0 1.6rem}
  .st-btn--blue.st-btn{box-shadow:0 8px 30px rgba(0,0,0,.3)}

  /* latest release */
  .st-release{padding:clamp(3.5rem,7vw,6rem) 0;background:#0e0e10}
  .st-release__grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,5vw,4rem);align-items:center}
  .st-release__art img{width:100%;aspect-ratio:1;object-fit:cover;box-shadow:0 24px 60px rgba(0,0,0,.5)}
  .st-release__body .st-h2{font-size:clamp(2rem,4vw,3rem);margin:.2rem 0 1rem}
  .st-release__body .st-script-text{margin-bottom:1.6rem}
  .st-tracks{list-style:none}
  .st-track{display:grid;grid-template-columns:34px 1fr auto 24px;align-items:center;gap:1rem;padding:.7rem 0;border-bottom:1px solid rgba(236,233,227,.1)}
  .st-track__n{font-family:'Caveat',cursive;color:#7e8a99;font-size:1.05rem}
  .st-track__name{font-family:'Caveat',cursive;font-size:1.35rem;color:#ece9e3}
  .st-track__t{font-family:'Caveat',cursive;color:#8a8780;font-size:1.05rem}
  .st-track__play{color:#7e8a99;font-size:.7rem;justify-self:end}

  /* tour */
  .st-tour{padding:clamp(3.5rem,7vw,5.5rem) 0}
  .st-tour__list{list-style:none}
  .st-tour__head{display:grid;grid-template-columns:170px 1fr 1.3fr auto;gap:1rem;font-family:'Caveat',cursive;text-transform:uppercase;letter-spacing:.12em;color:#7e8a99;font-size:1rem;padding-bottom:1rem;border-bottom:1px solid rgba(236,233,227,.18)}
  .st-tour__row{display:grid;grid-template-columns:170px 1fr 1.3fr auto;gap:1rem;align-items:center;padding:1.15rem 0;border-bottom:1px solid rgba(236,233,227,.12);font-family:'Caveat',cursive;font-size:1.35rem}
  .st-tour__date{color:#cfccc3}.st-tour__city{color:#ece9e3}.st-tour__venue{color:#8fb4d6}
  .st-tour__out{justify-self:end;font-family:'Caveat',cursive;font-size:1.05rem;color:#6b6b6b;border:1px solid #333;border-radius:4px;padding:.4rem 1rem;text-transform:uppercase;letter-spacing:.06em}
  .st-tour__row .st-btn{justify-self:end}
  @media(max-width:760px){.st-tour__head{display:none}.st-tour__row{grid-template-columns:1fr auto;grid-template-areas:"date act" "city act" "venue act";gap:.1rem 1rem}.st-tour__date{grid-area:date}.st-tour__city{grid-area:city}.st-tour__venue{grid-area:venue}.st-tour__row .st-btn,.st-tour__out{grid-area:act;align-self:center}}

  /* merch */
  .st-merch{padding:clamp(3.5rem,7vw,5.5rem) 0;background:#0e0e10}
  .st-merch__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.6rem}
  .st-merch__imgwrap{position:relative;aspect-ratio:1;overflow:hidden;background:#1a1a1c}
  .st-merch__imgwrap img{width:100%;height:100%;object-fit:cover}
  .st-soldout{position:absolute;top:.8rem;right:.8rem;font-family:'Caveat',cursive;background:#0c0c0d;color:#cfccc3;border:1px solid rgba(236,233,227,.25);padding:.2rem .8rem;border-radius:3px;text-transform:uppercase;letter-spacing:.06em;font-size:.95rem;transform:rotate(-2deg)}
  @media(max-width:760px){.st-merch__grid{grid-template-columns:1fr}}

  /* watch */
  .st-watch{padding:clamp(3.5rem,7vw,5.5rem) 0}
  .st-watch__sub{margin-bottom:2rem}
  .st-video{aspect-ratio:16/9;background:#161618;display:grid;place-items:center;border:1px solid rgba(236,233,227,.1)}
  .st-video__play{width:74px;height:74px;border-radius:50%;background:rgba(63,107,143,.85);color:#fff;display:grid;place-items:center;font-size:1.4rem;padding-left:5px}

  /* stay in touch */
  .st-touch{padding:clamp(3.5rem,7vw,5.5rem) 0;background:#0e0e10}
  .st-touch__listen{margin:1.6rem 0 .8rem}
  .st-touch__links{display:flex;gap:.8rem;flex-wrap:wrap}
  .st-stream{display:inline-flex;align-items:center;gap:.6rem;font-family:'Caveat',cursive;font-size:1.2rem;background:#161618;border:1px solid rgba(236,233,227,.14);color:#ece9e3;padding:.6rem 1.4rem;border-radius:6px;transition:.2s}
  .st-stream:hover{border-color:#3f6b8f;color:#fff}
  .st-stream svg{width:18px;height:18px}

  /* discography */
  .st-disco{padding:clamp(3.5rem,7vw,5.5rem) 0}
  .st-disco__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,300px));gap:2rem}
  .st-disco__item img{width:100%;aspect-ratio:1;object-fit:cover;box-shadow:0 16px 40px rgba(0,0,0,.4)}
  .st-disco__item h3{font-family:'Playfair Display',serif;font-weight:500;font-size:1.1rem;margin-top:.9rem;color:#ece9e3}

  /* footer */
  .st-foot{text-align:center;padding:3rem 1.5rem;border-top:1px solid rgba(236,233,227,.1);font-family:'Caveat',cursive;color:#7c7c78;font-size:1.1rem}
  .st-credit{margin-top:.3rem}
  .st-credit a{color:#8fb4d6}

  @media(max-width:760px){.st-release__grid{grid-template-columns:1fr}.st-nav{display:none}}
</style>
