---
import DemoLayout from '../../layouts/DemoLayout.astro';
import { themes } from '../../data/themes.js';
const theme = themes.find((t) => t.slug === 'frame');
const fonts = 'https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap';

const tour = [
  { date: 'Jan 15 2026', city: 'Los Angeles, CA', venue: 'The Wiltern', soldOut: false },
  { date: 'Jan 18 2026', city: 'San Francisco, CA', venue: 'The Fillmore', soldOut: false },
  { date: 'Jan 22 2026', city: 'Portland, OR', venue: 'Crystal Ballroom', soldOut: true },
  { date: 'Jan 25 2026', city: 'Seattle, WA', venue: 'The Showbox', soldOut: false },
  { date: 'Jan 28 2026', city: 'Vancouver, BC', venue: 'Commodore Ballroom', soldOut: false },
];
---
<DemoLayout theme={theme} fonts={fonts} title="ORPHN — Riffride Frame demo">
  <div class="fr-page">
    <!-- ============ MENU (full-screen overlay, :target-driven) ============ -->
    <div class="fr-menu" id="menu">
      <a class="fr-menu__close" href="#top" aria-label="Close menu">&times;</a>
      <nav class="fr-menu__nav">
        <a href="#top">Home</a>
        <a href="#listen">Listen</a>
        <a href="#tour">Tour</a>
        <a href="#contact">Contact</a>
      </nav>
      <div class="fr-menu__soc">
        <a href="#listen" aria-label="Spotify"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.6 14.4a.75.75 0 01-1 .25c-2.7-1.6-6.1-2-10.1-1.1a.75.75 0 11-.3-1.45c4.3-1 8.1-.5 11.1 1.3.36.22.47.69.3 1zm1.2-2.7a.94.94 0 01-1.3.3c-3-1.85-7.6-2.4-11.2-1.3a.94.94 0 11-.55-1.8c4.1-1.25 9.2-.65 12.7 1.5.44.27.58.85.35 1.3zm.1-2.8C14.6 8.1 8.9 7.9 5.6 8.9a1.12 1.12 0 11-.65-2.15c3.8-1.15 10.1-.9 14 1.4a1.12 1.12 0 01-1.15 1.95z"/></svg></a>
        <a href="#contact" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
        <a href="#contact" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 3c.3 2.2 1.7 3.8 4 4v2.6c-1.5 0-2.9-.5-4-1.3V15a5.5 5.5 0 1 1-5.5-5.5c.3 0 .6 0 .9.1v2.7a2.8 2.8 0 1 0 2 2.7V3H14z"/></svg></a>
        <a href="#contact" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.7-1.7C19.3 5.2 12 5.2 12 5.2s-7.3 0-8.9.4A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.7 1.7c1.6.4 8.9.4 8.9.4s7.3 0 8.9-.4a2.5 2.5 0 0 0 1.7-1.7C23 15.2 23 12 23 12zM9.8 15.3V8.7l5.7 3.3z"/></svg></a>
      </div>
    </div>

    <!-- ============ SPLASH ============ -->
    <section class="fr-splash" id="top">
      <video class="fr-video" autoplay muted loop playsinline>
        <source src="/demo/frame/bg.mp4" type="video/mp4" />
      </video>
      <div class="fr-scrim"></div>

      <!-- chrome -->
      <div class="fr-bar">
        <a class="fr-logo" href="#listen">ORPHN</a>
        <a class="fr-burger" href="#menu" aria-label="Open menu">
          <span></span><span></span><span></span>
        </a>
      </div>

      <!-- centre -->
      <div class="fr-centre">
        <a class="fr-art" href="#listen">
          <img src="/demo/frame/art.jpg" alt="Public Order — new single" />
        </a>
        <p class="fr-eyebrow">New Single — Listen ↗</p>
      </div>

      <!-- socials -->
      <div class="fr-soc">
        <a href="#listen" aria-label="Spotify"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.6 14.4a.75.75 0 01-1 .25c-2.7-1.6-6.1-2-10.1-1.1a.75.75 0 11-.3-1.45c4.3-1 8.1-.5 11.1 1.3.36.22.47.69.3 1zm1.2-2.7a.94.94 0 01-1.3.3c-3-1.85-7.6-2.4-11.2-1.3a.94.94 0 11-.55-1.8c4.1-1.25 9.2-.65 12.7 1.5.44.27.58.85.35 1.3zm.1-2.8C14.6 8.1 8.9 7.9 5.6 8.9a1.12 1.12 0 11-.65-2.15c3.8-1.15 10.1-.9 14 1.4a1.12 1.12 0 01-1.15 1.95z"/></svg></a>
        <a href="#contact" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
        <a href="#contact" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 3c.3 2.2 1.7 3.8 4 4v2.6c-1.5 0-2.9-.5-4-1.3V15a5.5 5.5 0 1 1-5.5-5.5c.3 0 .6 0 .9.1v2.7a2.8 2.8 0 1 0 2 2.7V3H14z"/></svg></a>
        <a href="#contact" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.7-1.7C19.3 5.2 12 5.2 12 5.2s-7.3 0-8.9.4A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.7 1.7c1.6.4 8.9.4 8.9.4s7.3 0 8.9-.4a2.5 2.5 0 0 0 1.7-1.7C23 15.2 23 12 23 12zM9.8 15.3V8.7l5.7 3.3z"/></svg></a>
      </div>
    </section>

    <!-- ============ LISTEN ============ -->
    <section class="fr-section" id="listen">
      <div class="fr-wrap">
        <span class="fr-dash"></span>
        <h1 class="fr-h1">Listen</h1>
        <div class="fr-player">
          <iframe style="border-radius:12px" src="https://open.spotify.com/embed/artist/0cmWgDlu9CwTgxPhf403hb?theme=0" width="100%" height="352" frameborder="0" allow="autoplay;clipboard-write;encrypted-media;fullscreen;picture-in-picture" loading="lazy"></iframe>
        </div>
        <p class="fr-caption">New Single — Public Order — Out Now</p>
      </div>
    </section>

    <!-- ============ TOUR ============ -->
    <section class="fr-section" id="tour">
      <div class="fr-wrap">
        <span class="fr-dash"></span>
        <h1 class="fr-h1">Tour Dates</h1>
        <table class="fr-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>City</th>
              <th>Venue</th>
            </tr>
          </thead>
          <tbody>
            {tour.map((t) => (
              <tr>
                <td class="fr-td-date">{t.date}</td>
                <td class="fr-td-city">{t.city}</td>
                <td class="fr-td-venue">
                  {t.venue}
                  {t.soldOut && <span class="fr-pill">Sold Out</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ============ CONTACT ============ -->
    <section class="fr-section" id="contact">
      <div class="fr-wrap">
        <span class="fr-dash"></span>
        <h1 class="fr-h1">Get in touch</h1>
        <p class="fr-sub">Sign up for updates on new releases, tour dates, and exclusive content.</p>

        <p class="fr-label">Listen</p>
        <div class="fr-pills">
          <a class="fr-link" href="#listen">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.6 14.4a.75.75 0 01-1 .25c-2.7-1.6-6.1-2-10.1-1.1a.75.75 0 11-.3-1.45c4.3-1 8.1-.5 11.1 1.3.36.22.47.69.3 1zm1.2-2.7a.94.94 0 01-1.3.3c-3-1.85-7.6-2.4-11.2-1.3a.94.94 0 11-.55-1.8c4.1-1.25 9.2-.65 12.7 1.5.44.27.58.85.35 1.3zm.1-2.8C14.6 8.1 8.9 7.9 5.6 8.9a1.12 1.12 0 11-.65-2.15c3.8-1.15 10.1-.9 14 1.4a1.12 1.12 0 01-1.15 1.95z"/></svg>
            <span>Spotify</span>
          </a>
          <a class="fr-link" href="#listen">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 12.6c0-1.9 1.5-2.8 1.6-2.9-.9-1.3-2.3-1.5-2.8-1.5-1.2-.1-2.3.7-2.9.7-.6 0-1.5-.7-2.5-.7-1.3 0-2.5.7-3.2 1.9-1.3 2.4-.3 5.9 1 7.8.6 1 1.4 2 2.4 2 1-.04 1.3-.6 2.5-.6 1.2 0 1.5.6 2.5.6 1 0 1.7-.9 2.3-1.9.7-1.1 1-2.2 1-2.2-.02-.01-1.9-.7-1.9-2.8zM14.6 6.2c.5-.6.9-1.5.8-2.4-.8.03-1.7.5-2.3 1.2-.5.6-.9 1.5-.8 2.3.9.07 1.8-.5 2.3-1.1z"/></svg>
            <span>Apple Music</span>
          </a>
        </div>

        <p class="fr-label">Follow</p>
        <div class="fr-pills">
          <a class="fr-link" href="#contact">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            <span>Instagram</span>
          </a>
          <a class="fr-link" href="#contact">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.7-1.7C19.3 5.2 12 5.2 12 5.2s-7.3 0-8.9.4A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.7 1.7c1.6.4 8.9.4 8.9.4s7.3 0 8.9-.4a2.5 2.5 0 0 0 1.7-1.7C23 15.2 23 12 23 12zM9.8 15.3V8.7l5.7 3.3z"/></svg>
            <span>YouTube</span>
          </a>
          <a class="fr-link" href="#contact">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 3c.3 2.2 1.7 3.8 4 4v2.6c-1.5 0-2.9-.5-4-1.3V15a5.5 5.5 0 1 1-5.5-5.5c.3 0 .6 0 .9.1v2.7a2.8 2.8 0 1 0 2 2.7V3H14z"/></svg>
            <span>TikTok</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="fr-footer">
      <p class="fr-copy">© 2026 · ORPHN</p>
      <p class="fr-credit">Created with <a href="/">Riffride</a></p>
    </footer>
  </div>
</DemoLayout>

<style>
  .fr-page{background:#0A0A0A;color:#FFFFFF;font-family:'Space Mono',monospace}

  /* ---------- SPLASH ---------- */
  .fr-splash{position:relative;min-height:calc(100vh - 42px);overflow:hidden;display:grid;place-items:center}
  .fr-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;filter:grayscale(1) contrast(1.05)}
  .fr-scrim{position:absolute;inset:0;z-index:1;background:radial-gradient(circle at 50% 45%,rgba(10,10,10,.3),rgba(10,10,10,.78))}

  .fr-bar{position:absolute;top:0;left:0;right:0;z-index:3;display:flex;align-items:center;justify-content:space-between;padding:1.5rem clamp(1.25rem,4vw,2.5rem)}
  .fr-logo{font-family:'Oswald',sans-serif;font-weight:700;font-size:1.4rem;letter-spacing:.34em;color:#FFFFFF}
  .fr-burger{display:flex;flex-direction:column;gap:5px;width:26px;cursor:pointer}
  .fr-burger span{display:block;height:2px;width:100%;background:#FFFFFF;transition:opacity .2s}
  .fr-burger:hover span{opacity:.7}

  .fr-centre{position:relative;z-index:2;text-align:center;padding:2rem}
  .fr-art{display:inline-block;width:min(72vw,330px)}
  .fr-art img{width:100%;aspect-ratio:1;object-fit:cover;box-shadow:0 24px 70px rgba(0,0,0,.6);transition:transform .4s ease,box-shadow .4s ease}
  .fr-art:hover img{transform:scale(1.03);box-shadow:0 30px 90px rgba(0,0,0,.75)}
  .fr-eyebrow{margin-top:1.2rem;text-transform:uppercase;letter-spacing:.32em;font-size:.74rem;color:#FFFFFF}

  .fr-soc{position:absolute;bottom:2.4rem;left:50%;transform:translateX(-50%);z-index:3;display:flex;gap:1.5rem}
  .fr-soc a{color:rgba(255,255,255,.8);transition:color .2s;display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;border:1px solid rgba(255,255,255,.25);border-radius:50%}
  .fr-soc a:hover{color:#FFFFFF;border-color:rgba(255,255,255,.6)}
  .fr-soc svg{width:18px;height:18px}

  /* ---------- MENU OVERLAY (animated, :target) ---------- */
  .fr-menu{position:fixed;inset:0;z-index:200;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:clamp(2rem,5vw,3.4rem);background:rgba(8,8,8,.98);opacity:0;visibility:hidden;pointer-events:none;transition:opacity .5s ease,visibility .5s ease}
  .fr-menu:target{opacity:1;visibility:visible;pointer-events:auto}
  .fr-menu__close{position:absolute;top:3.4rem;right:clamp(1.25rem,4vw,2.5rem);font-family:'Oswald',sans-serif;font-weight:300;font-size:2.8rem;line-height:1;color:#fff;transition:color .2s,transform .3s}
  .fr-menu__close:hover{color:#9A9A9A;transform:rotate(90deg)}
  .fr-menu__nav{display:flex;flex-direction:column;align-items:center;gap:clamp(1rem,2.6vw,1.7rem)}
  .fr-menu__nav a{font-family:'Oswald',sans-serif;font-weight:600;text-transform:uppercase;letter-spacing:.16em;font-size:clamp(2rem,6.5vw,3.6rem);line-height:1;color:#fff;opacity:0;transform:translateY(28px);transition:opacity .55s ease,transform .55s ease,color .2s}
  .fr-menu__nav a:hover{color:#9A9A9A}
  .fr-menu:target .fr-menu__nav a{opacity:1;transform:translateY(0)}
  .fr-menu:target .fr-menu__nav a:nth-child(1){transition-delay:.1s}
  .fr-menu:target .fr-menu__nav a:nth-child(2){transition-delay:.18s}
  .fr-menu:target .fr-menu__nav a:nth-child(3){transition-delay:.26s}
  .fr-menu:target .fr-menu__nav a:nth-child(4){transition-delay:.34s}
  .fr-menu__soc{display:flex;gap:1.4rem;opacity:0;transform:translateY(20px);transition:opacity .5s ease .42s,transform .5s ease .42s}
  .fr-menu:target .fr-menu__soc{opacity:1;transform:translateY(0)}
  .fr-menu__soc a{color:rgba(255,255,255,.8);display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;border:1px solid rgba(255,255,255,.25);border-radius:50%;transition:color .2s,border-color .2s}
  .fr-menu__soc a:hover{color:#fff;border-color:rgba(255,255,255,.6)}
  .fr-menu__soc svg{width:18px;height:18px}

  /* ---------- SECTIONS ---------- */
  .fr-section{background:#0A0A0A;padding:clamp(3.5rem,8vw,6rem) clamp(1.25rem,4vw,2.5rem);border-top:1px solid #161616}
  .fr-wrap{max-width:760px;margin:0 auto}
  .fr-dash{display:block;width:42px;height:2px;background:#9A9A9A;margin-bottom:1.2rem}
  .fr-h1{font-family:'Oswald',sans-serif;font-weight:700;font-size:clamp(2.4rem,6vw,3.6rem);letter-spacing:.01em;line-height:1;color:#FFFFFF;text-transform:uppercase;margin-bottom:2rem}

  /* LISTEN */
  .fr-player{background:#181818;border:1px solid #222;border-radius:16px;padding:14px}
  .fr-player iframe{display:block}
  .fr-caption{margin-top:1.1rem;text-transform:uppercase;letter-spacing:.22em;font-size:.72rem;color:#9A9A9A}

  /* TOUR */
  .fr-table{width:100%;border-collapse:collapse;font-size:.82rem}
  .fr-table th{text-align:left;text-transform:uppercase;letter-spacing:.2em;font-size:.68rem;font-weight:700;color:#9A9A9A;padding:0 1rem .9rem;border-bottom:1px solid #2a2a2a}
  .fr-table td{padding:1.1rem 1rem;border-bottom:1px solid #1c1c1c;vertical-align:middle}
  .fr-td-date{font-weight:700;color:#FFFFFF;white-space:nowrap}
  .fr-td-city{color:#9A9A9A}
  .fr-td-venue{color:#B3B3B3}
  .fr-pill{display:inline-block;margin-left:.8rem;padding:.22em .7em;border:1px solid #444;border-radius:999px;font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;color:#9A9A9A;vertical-align:middle}

  /* CONTACT */
  .fr-sub{color:#9A9A9A;font-size:.85rem;line-height:1.6;max-width:46ch;margin-bottom:2.4rem}
  .fr-label{text-transform:uppercase;letter-spacing:.24em;font-size:.7rem;font-weight:700;color:#FFFFFF;margin-bottom:1rem}
  .fr-pills{display:flex;flex-wrap:wrap;gap:.8rem;margin-bottom:2.4rem}
  .fr-link{display:inline-flex;align-items:center;gap:.6rem;border:1px solid #333;border-radius:999px;padding:.7rem 1.4rem;color:#FFFFFF;text-transform:uppercase;letter-spacing:.16em;font-size:.72rem;background:#111;transition:border-color .2s,background .2s}
  .fr-link:hover{border-color:#777;background:#1A1A1A}
  .fr-link svg{width:17px;height:17px}

  /* ---------- FOOTER ---------- */
  .fr-footer{background:#0D0D0D;border-top:1px solid #161616;text-align:center;padding:3rem 1.25rem 2.6rem}
  .fr-copy{text-transform:uppercase;letter-spacing:.24em;font-size:.72rem;color:#9A9A9A}
  .fr-credit{margin-top:.9rem;text-transform:uppercase;letter-spacing:.16em;font-size:.66rem;color:#6a6a6a}
  .fr-credit a{color:#9A9A9A}
  .fr-credit a:hover{color:#FFFFFF}

  @media (max-width:560px){
    .fr-soc{gap:1rem}
    .fr-soc a{width:38px;height:38px}
    .fr-table{font-size:.74rem}
    .fr-table td{padding:.9rem .6rem}
    .fr-table th{padding:0 .6rem .8rem}
    .fr-pill{display:block;margin:.5rem 0 0;width:max-content}
  }
</style>
