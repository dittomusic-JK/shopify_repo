---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Marquee from '../components/Marquee.astro';
import ThemeCard from '../components/ThemeCard.astro';
import Footer from '../components/Footer.astro';
import { themes } from '../data/themes.js';

const features = [
  { name: 'Storefront', desc: 'A full Shopify store — cart, checkout and secure payments, built in.', img: '/icons/shopify_store.png' },
  { name: 'Spotify embed', desc: 'Embed your latest release and let fans play it right on the page.', img: '/icons/spotify_embed.png' },
  { name: 'MusicBrainz sync', desc: 'Auto-pull your verified discography straight from the MusicBrainz database.', img: '/icons/music_brainz.png' },
  { name: 'EPK builder', desc: 'A press-ready electronic press kit for blogs, promoters and labels.', img: '/icons/epk.png' },
  { name: 'Discography', desc: 'Showcase every album and single with full artwork and tracklists.', img: '/icons/discography.png' },
  { name: 'Tour dates', desc: 'List shows with venues, ticket links and sold-out states.', img: '/icons/tour.png' },
  { name: 'On-demand merch', desc: 'Print-on-demand via Printful, Printify and Gelato — no stock to hold.', img: '/icons/merch.png' },
  { name: 'Photo galleries', desc: 'Editorial galleries and lookbooks to show off your whole world.', img: '/icons/gallery.png' },
  { name: 'Links and socials', desc: 'Plug in every platform — Spotify, Apple, Bandcamp, Instagram, TikTok and more.', img: '/icons/links.png' },
];
---
<Base>
  <Header />

  <!-- HERO -->
  <section id="top" class="relative overflow-hidden py-[clamp(3.5rem,9vw,7rem)]" style="background:radial-gradient(ellipse 70% 60% at 72% 38%,rgba(154,115,236,.26),transparent 60%),var(--color-dark)">
    <!-- floating theme screenshots, faded behind the hero art -->
    <div class="hidden md:block absolute inset-0 z-[1] pointer-events-none" aria-hidden="true">
      <img src="/thumbs/riot.jpg" class="hero-screen" style="width:152px;top:5%;right:31%;transform:rotate(-9deg);opacity:.34" />
      <img src="/thumbs/vesper.jpg" class="hero-screen" style="width:170px;top:31%;right:3%;transform:rotate(7deg);opacity:.3" />
      <img src="/thumbs/wander.jpg" class="hero-screen" style="width:140px;bottom:3%;right:27%;transform:rotate(-6deg);opacity:.26" />
      <img src="/thumbs/block.jpg" class="hero-screen" style="width:128px;top:10%;right:0;transform:rotate(12deg);opacity:.22" />
    </div>
    <div class="max-w-[1180px] mx-auto px-5 sm:px-10 grid md:grid-cols-[1.25fr_.75fr] gap-8 items-center relative z-[2]">
      <div class="reveal">
        <h1 class="font-funk uppercase text-[clamp(2.9rem,8.2vw,6.2rem)] leading-[1.02]" style="text-shadow:4px 4px 0 rgba(0,0,0,.25)">Shopify themes for <span class="text-purple">artists &amp; musicians</span></h1>
        <p class="mt-6 mb-8 text-[clamp(1.02rem,1.6vw,1.22rem)] text-[#d4cee2] max-w-[44ch]">Music, merch, tour dates, press kit, galleries and links — everything a working musician needs, in one site you build yourself and actually own. No code, no developer. You can even sell your merch right on Spotify.</p>
        <div class="flex flex-wrap gap-3.5">
          <a href="#templates" class="btn btn-purple">See the themes</a>
          <a href="/setup" class="btn btn-ghost">Start free</a>
        </div>
      </div>
      <div class="hero-art reveal flex items-center justify-center">
        <img src="/hero_graphic.webp" alt="Built for creatives. Made to sell. Ready to rock." class="w-full max-w-[470px] h-auto" style="filter:drop-shadow(0 16px 36px rgba(154,115,236,.45))" />
      </div>
    </div>
  </section>

  <Marquee />

  <!-- TEMPLATES -->
  <section id="templates" class="bg-cream text-ink py-[clamp(3.5rem,8vw,6rem)]">
    <div class="max-w-[1180px] mx-auto px-5 sm:px-10">
      <div class="reveal text-center max-w-[660px] mx-auto mb-[clamp(2.2rem,4vw,3.2rem)]">
        <h2 class="head-underline font-funk text-[clamp(2.2rem,5.5vw,3.6rem)] leading-[1.02]">The themes</h2>
        <p class="mt-3.5 text-[#5e576b] text-[1.08rem]">Every one is a complete musician website. Pick your look, make it yours, go live.</p>
      </div>
      <div class="grid gap-6" style="grid-template-columns:repeat(auto-fill,minmax(270px,1fr))">
        {themes.map((t, i) => <ThemeCard theme={t} delay={i === 0 ? '' : 'd' + Math.min(i, 6)} />)}
      </div>
    </div>

  </section>

  <!-- FEATURES — everything included -->
  <section id="features" class="bg-dark py-[clamp(3.5rem,8vw,6rem)]">
    <div class="max-w-[1180px] mx-auto px-5 sm:px-10">
      <div class="reveal text-center max-w-[680px] mx-auto mb-[clamp(2.4rem,5vw,3.4rem)]">
        <h2 class="head-underline font-funk text-[clamp(2.2rem,5.5vw,3.6rem)] leading-[1.02]">Everything's <span class="text-purple">included</span></h2>
        <p class="mt-4 text-[#cfc8dd] text-[1.05rem]">Free or premium, every Riffride theme ships with the full toolkit — no apps to bolt on, no add-ons to buy.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {features.map((f, i) => (
          <div class={`reveal feat-card ${i > 0 ? 'd' + Math.min(i % 6, 6) : ''}`}>
            <img class="feat-ic-img" src={f.img} alt="" loading="lazy" width="78" height="78" />
            <h4 class="font-display text-[1.05rem] uppercase tracking-[.02em] text-cream">{f.name}</h4>
            <p class="text-[#a89fbb] text-[.86rem] mt-1.5 leading-[1.55]">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="relative overflow-hidden py-[clamp(3.5rem,8vw,5.5rem)]" style="background:radial-gradient(circle at 30% 50%,rgba(154,115,236,.16),transparent 55%),var(--color-dark)">
    <div class="reveal relative z-[2] max-w-[760px] mx-auto px-5 text-center">
      <h2 class="font-funk text-[clamp(2rem,5vw,3rem)] leading-[1.05]">One site for your <span class="text-purple">whole career</span></h2>
      <p class="text-[#d4cee2] text-[1.1rem] mt-4">Most artists scatter everything across a Linktree, a separate merch store and a press-kit PDF. Riffride brings it all together — music, merch, tour dates, press kit and links — on one professional site you build, customise and actually own. No designers, no developers, no big budget. And yes: connect it to Spotify and your merch shows right on your artist profile.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="bg-dark pb-[clamp(3.5rem,8vw,5.5rem)]">
    <div class="max-w-[760px] mx-auto px-5 sm:px-10">
      <h2 class="font-funk text-[clamp(1.8rem,4.5vw,2.6rem)] text-center mb-6">FAQ</h2>
      <details class="reveal" open>
        <summary>Do I need a Shopify account?</summary>
        <p>Yes — the themes run on Shopify, with plans from around $5/month. The free theme works on any plan, and the built-in setup guide points you to the right one.</p>
      </details>
      <details class="reveal">
        <summary>How do I install the theme?</summary>
        <p>You get a .zip file plus a step-by-step setup guide built right into the theme. Upload it in your Shopify admin, follow the guide, and you're live — usually the same day.</p>
      </details>
      <details class="reveal">
        <summary>What's the difference between the free and paid themes?</summary>
        <p>The free Standard theme has everything you need to launch and sell. The $50 themes are bespoke designs with extra polish, premium-only sections, and they remove the "Created with Riffride" credit.</p>
      </details>
      <details class="reveal">
        <summary>Can I really sell merch on Spotify?</summary>
        <p>Yes. Connect your Shopify store to Spotify for Artists and your merch shows on your artist profile, release pages and Now Playing. The setup guide walks you through every step.</p>
      </details>
      <div class="reveal text-center mt-8">
        <p class="text-[#bdb6cc] mb-4">Need the step-by-step? We spell out menus, pages, merch and more — in plain English.</p>
        <a href="/help" class="btn btn-purple">Browse the setup guides</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>
