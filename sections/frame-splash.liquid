{%- comment -%}
  Riffride Frame — full-screen video splash. Background video (or image),
  an optional centred artwork that links anywhere (release art / GIF), and a
  row of social icons bottom-centre (pulled from theme social/streaming settings).
  Logo top-left + burger top-right come from the header (see frame.css).
{%- endcomment -%}

{%- liquid
  assign sid = 'frame-splash-' | append: section.id
  assign ov = section.settings.overlay_opacity | default: 35 | divided_by: 100.0
-%}

<style>
  #{{ sid }} { position: relative; min-height: 100vh; width: 100%; overflow: hidden; background: var(--brand-bg-0); }
  #{{ sid }} .fs__media, #{{ sid }} .fs__media img, #{{ sid }} .fs__media video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  #{{ sid }} .fs__overlay { position: absolute; inset: 0; background: #000; opacity: {{ ov }}; }
  #{{ sid }} .fs__centre { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: min(70vw, 360px); text-align: center; z-index: 2; }
  #{{ sid }} .fs__art { display: block; text-decoration: none; }
  #{{ sid }} .fs__art img { width: 100%; height: auto; display: block; }
  #{{ sid }} .fs__art-placeholder { aspect-ratio: 1; border: 1px solid rgba(255,255,255,0.25); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.5); font-family: var(--font-heading); letter-spacing: 0.2em; font-size: 0.8rem; }
  #{{ sid }} .fs__caption { margin-top: 0.9rem; color: #fff; font-family: var(--font-heading); text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.8rem; }
  #{{ sid }} .fs__socials { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; gap: 1.4rem; z-index: 2; }
  #{{ sid }} .fs__socials a { color: #fff; opacity: 0.85; transition: opacity 0.2s ease; display: inline-flex; }
  #{{ sid }} .fs__socials a:hover { opacity: 1; }
  #{{ sid }} .fs__socials svg { width: 22px; height: 22px; }
</style>

<section id="{{ sid }}" class="frame-splash">
  {%- if section.settings.background_video != blank -%}
    <div class="fs__media" aria-hidden="true">
      <video autoplay muted loop playsinline poster="{{ section.settings.background_image | image_url: width: 2400 }}">
        <source src="{{ section.settings.background_video | file_url }}" type="video/mp4">
      </video>
    </div>
  {%- elsif section.settings.background_image != blank -%}
    <div class="fs__media" aria-hidden="true">
      <img src="{{ section.settings.background_image | image_url: width: 2400 }}" alt="" loading="eager" fetchpriority="high">
    </div>
  {%- endif -%}
  <div class="fs__overlay" aria-hidden="true"></div>

  {%- if section.settings.artwork_image != blank or section.settings.caption != blank -%}
    <div class="fs__centre">
      <a class="fs__art" href="{{ section.settings.artwork_link | default: '#' }}"{% if section.settings.artwork_link contains 'http' %} target="_blank" rel="noopener noreferrer"{% endif %}>
        {%- if section.settings.artwork_image != blank -%}
          <img src="{{ section.settings.artwork_image | image_url: width: 800 }}" alt="{{ section.settings.caption | escape }}" loading="eager">
        {%- else -%}
          <span class="fs__art-placeholder">ARTWORK</span>
        {%- endif -%}
        {%- if section.settings.caption != blank -%}<span class="fs__caption">{{ section.settings.caption }}</span>{%- endif -%}
      </a>
    </div>
  {%- endif -%}

  <div class="fs__socials">
    {%- if settings.spotify_url != blank -%}<a href="{{ settings.spotify_url }}" target="_blank" rel="noopener" aria-label="Spotify"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.6 14.4a.75.75 0 01-1 .25c-2.7-1.6-6.1-2-10.1-1.1a.75.75 0 11-.3-1.45c4.3-1 8.1-.5 11.1 1.3.36.22.47.69.3 1zm1.2-2.7a.94.94 0 01-1.3.3c-3-1.85-7.6-2.4-11.2-1.3a.94.94 0 11-.55-1.8c4.1-1.25 9.2-.65 12.7 1.5.44.27.58.85.35 1.3zm.1-2.8C14.6 8.1 8.9 7.9 5.6 8.9a1.12 1.12 0 11-.65-2.15c3.8-1.15 10.1-.9 14 1.4a1.12 1.12 0 01-1.15 1.95z"/></svg></a>{%- endif -%}
    {%- if settings.apple_music_url != blank -%}<a href="{{ settings.apple_music_url }}" target="_blank" rel="noopener" aria-label="Apple Music"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 3l-7 1.5v9.1a3 3 0 10 1.5 2.6V8l4-.86v4.2a3 3 0 101.5 2.6V3z"/></svg></a>{%- endif -%}
    {%- if settings.instagram_url != blank -%}<a href="{{ settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>{%- endif -%}
    {%- if settings.tiktok_url != blank -%}<a href="{{ settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 3c.3 2.2 1.7 3.8 4 4v2.6c-1.5 0-2.9-.5-4-1.3V15a5.5 5.5 0 11-5.5-5.5c.3 0 .6 0 .9.1v2.7a2.8 2.8 0 102 2.7V3h2.6z"/></svg></a>{%- endif -%}
    {%- if settings.youtube_url != blank -%}<a href="{{ settings.youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 00-1.7-1.7C19.3 5.2 12 5.2 12 5.2s-7.3 0-8.9.4A2.5 2.5 0 001.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 001.7 1.7c1.6.4 8.9.4 8.9.4s7.3 0 8.9-.4a2.5 2.5 0 001.7-1.7C23 15.2 23 12 23 12zM9.8 15.3V8.7l5.7 3.3-5.7 3.3z"/></svg></a>{%- endif -%}
  </div>
</section>

{%- schema -%}
{
  "name": "Frame splash",
  "tag": "section",
  "settings": [
    { "type": "video", "id": "background_video", "label": "Background video", "info": "MP4, muted + looping. The hero of the page." },
    { "type": "image_picker", "id": "background_image", "label": "Background image", "info": "Fallback / video poster." },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "default": 35, "unit": "%", "label": "Overlay darkness" },
    { "type": "header", "content": "Centre artwork (optional link)" },
    { "type": "image_picker", "id": "artwork_image", "label": "Centre image / artwork", "info": "Release artwork or a GIF — clicks through to the link below." },
    { "type": "url", "id": "artwork_link", "label": "Artwork link", "info": "Smart link, Spotify, a new page, etc." },
    { "type": "text", "id": "caption", "label": "Caption under artwork", "default": "New single — Listen" }
  ],
  "presets": [ { "name": "Frame splash" } ]
}
{%- endschema -%}
