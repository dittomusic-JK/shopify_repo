{%- comment -%}
  Riffride — Setup Guide
  The "quick path to merch on Spotify" walkthrough. Designed to be added to a
  hidden /pages/setup page the merchant uses while configuring their store.
  Pulls affiliate/referral links from theme settings via riffride-referral.
{%- endcomment -%}

{%- liquid
  assign merch_provider = settings.riffride_merch_provider | default: 'printful' | capitalize
  assign smartlink_provider = settings.riffride_smartlink_provider | default: 'ditto'
  case smartlink_provider
    when 'linkfire'
      assign smartlink_name = 'Linkfire'
    when 'featurefm'
      assign smartlink_name = 'Feature.fm'
    when 'none'
      assign smartlink_name = 'a smart-link service'
    else
      assign smartlink_name = 'Ditto'
  endcase
-%}

<style>
  .riffride-setup { background: var(--color-brand-bg, #0a0a0a); color: var(--color-brand-primary, #fff); padding: var(--space-xl, 8rem) var(--space-md, 2rem); }
  .riffride-setup__inner { max-width: 820px; margin: 0 auto; }
  .riffride-setup__eyebrow { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand-accent, #e8593c); margin: 0 0 1rem; }
  .riffride-setup__title { font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 700; line-height: 1.05; margin: 0 0 1rem; }
  .riffride-setup__lede { font-size: 1.125rem; line-height: 1.6; color: var(--color-brand-secondary, #999); margin: 0 0 3.5rem; }
  .riffride-step { display: grid; grid-template-columns: 3rem 1fr; gap: 1.5rem; padding: 2rem 0; border-top: 1px solid rgba(255,255,255,0.08); }
  .riffride-step__num { width: 3rem; height: 3rem; border-radius: 50%; border: 2px solid var(--color-brand-accent, #e8593c); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1rem; }
  .riffride-step__title { font-size: 1.35rem; font-weight: 700; margin: 0.25rem 0 0.5rem; }
  .riffride-step__body { color: var(--color-brand-secondary, #aaa); line-height: 1.6; margin: 0 0 1rem; }
  .riffride-step__body ol { margin: 0.5rem 0 0; padding-left: 1.2rem; }
  .riffride-step__body li { margin-bottom: 0.4rem; }
  .riffride-step__cta { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--color-brand-accent, #e8593c); color: #fff; text-decoration: none; font-weight: 600; padding: 0.7rem 1.4rem; border-radius: 6px; font-size: 0.95rem; }
  .riffride-step__cta:hover { opacity: 0.9; }
  .riffride-setup__note { margin-top: 3rem; padding: 1.25rem 1.5rem; border-left: 3px solid var(--color-brand-accent, #e8593c); background: rgba(255,255,255,0.03); font-size: 0.95rem; color: var(--color-brand-secondary, #aaa); }
</style>

<section class="riffride-setup">
  <div class="riffride-setup__inner">
    {%- if section.settings.eyebrow != blank -%}<p class="riffride-setup__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    <h1 class="riffride-setup__title">{{ section.settings.heading | default: 'Get your merch on Spotify' }}</h1>
    {%- if section.settings.lede != blank -%}<p class="riffride-setup__lede">{{ section.settings.lede }}</p>{%- endif -%}

    {%- comment -%} Step 1 — Merch with zero inventory {%- endcomment -%}
    <div class="riffride-step">
      <div class="riffride-step__num">1</div>
      <div>
        <h2 class="riffride-step__title">Add merch — no inventory, no upfront cost</h2>
        <p class="riffride-step__body">Install a print-on-demand app and connect it to your store. Products are printed and shipped on demand, so you pay nothing until a fan buys. We recommend Printful (easiest) — or pick whichever suits you.</p>
        <a class="riffride-step__cta" href="{% render 'riffride-referral', url: 'https://www.printful.com/a/5712245:0aca4da7a9719dac375172c1cc754cb2', campaign: 'setup_printful' %}" target="_blank" rel="noopener sponsored">Install Printful →</a>
        <p class="riffride-step__body" style="margin-top: 1rem; font-size: 0.85rem;">Prefer another?
          <a href="{% render 'riffride-referral', url: 'https://try.printify.com/atg42obyjxuj', campaign: 'setup_printify' %}" target="_blank" rel="noopener sponsored" style="color: var(--color-brand-accent);">Printify</a> ·
          <a href="{% render 'riffride-referral', url: 'https://try.gelato.com/or8oijoe11gn', campaign: 'setup_gelato' %}" target="_blank" rel="noopener sponsored" style="color: var(--color-brand-accent);">Gelato</a>
        </p>
      </div>
    </div>

    {%- comment -%} Step 2 — Connect store to Spotify {%- endcomment -%}
    <div class="riffride-step">
      <div class="riffride-step__num">2</div>
      <div>
        <h2 class="riffride-step__title">Connect your store to Spotify for Artists</h2>
        <p class="riffride-step__body">This is the part most artists don't know they can do — for free.</p>
        <div class="riffride-step__body">
          <ol>
            <li>Log in at <strong>artists.spotify.com</strong> and open <strong>Merch &amp; Events</strong>.</li>
            <li>Click <strong>Connect store</strong> and enter your <strong>your-store.myshopify.com</strong> URL.</li>
            <li>Back in Shopify, add <strong>Spotify</strong> as a sales channel, accept the terms, and choose the artist to link.</li>
          </ol>
        </div>
        <a class="riffride-step__cta" href="https://artists.spotify.com/en/merch" target="_blank" rel="noopener">Open Spotify for Artists →</a>
      </div>
    </div>

    {%- comment -%} Step 3 — Publish merch {%- endcomment -%}
    <div class="riffride-step">
      <div class="riffride-step__num">3</div>
      <div>
        <h2 class="riffride-step__title">Publish your merch to Spotify</h2>
        <p class="riffride-step__body">Once connected, publish up to 250 items from Shopify to Spotify, and pin up to 5 to the top of your profile. Items can take up to an hour to appear. Fans then see your merch on your artist profile, release pages, and the Now Playing view.</p>
      </div>
    </div>

    {%- comment -%} Step 4 — Smart link {%- endcomment -%}
    <div class="riffride-step">
      <div class="riffride-step__num">4</div>
      <div>
        <h2 class="riffride-step__title">Set up your smart link</h2>
        <p class="riffride-step__body">A smart link sends fans to their preferred streaming platform from one URL. Create one with {{ smartlink_name }} and paste it into your release and hero sections in the theme editor.</p>
        {%- if settings.riffride_smartlink_signup_url != blank and smartlink_provider != 'none' -%}
          <a class="riffride-step__cta" href="{% render 'riffride-referral', url: settings.riffride_smartlink_signup_url, campaign: 'setup_smartlink' %}" target="_blank" rel="noopener sponsored">Get a smart link with {{ smartlink_name }} →</a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Step 5 — Discoverability {%- endcomment -%}
    <div class="riffride-step">
      <div class="riffride-step__num">5</div>
      <div>
        <h2 class="riffride-step__title">Get found on Google</h2>
        <p class="riffride-step__body">In <strong>Theme settings → Artist Branding</strong> and <strong>Social Media</strong>, fill in your name, bio, photo, and every profile link. Riffride outputs this as structured data so Google can build your artist knowledge panel — tour dates, bio, socials, and music. For best results, also claim your <strong>Bandsintown</strong> and <strong>MusicBrainz</strong> profiles and add those links too.</p>
      </div>
    </div>

    <div class="riffride-setup__note">
      <strong>Tip:</strong> Shopify isn't free, but it's cheap — plans start around $5/month, and print-on-demand means zero inventory cost. That's the whole "quick path": a low monthly fee and you're selling merch on Spotify.
    </div>
  </div>
</section>

{%- schema -%}
{
  "name": "Riffride Setup Guide",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Start here"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get your merch on Spotify"
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Intro text",
      "default": "Five steps from empty store to merch live on your Spotify profile. No inventory, no design skills, no big budget."
    }
  ],
  "presets": [
    {
      "name": "Riffride Setup Guide"
    }
  ]
}
{%- endschema -%}
