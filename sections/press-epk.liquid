{{ 'section-press-epk.css' | asset_url | stylesheet_tag }}

<section id="press" class="press-epk">
  <div class="press-epk__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="press-epk__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if settings.artist_bio_short != blank -%}
      <div class="press-epk__bio">
        <p>{{ settings.artist_bio_short }}</p>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="press-epk__quotes">
        {%- for block in section.blocks -%}
          <blockquote class="press-quote" {{ block.shopify_attributes }}>
            {%- if block.settings.quote_text != blank -%}
              <p class="press-quote__text">"{{ block.settings.quote_text }}"</p>
            {%- endif -%}
            {%- if block.settings.publication_name != blank or block.settings.publication_logo != blank -%}
              <footer class="press-quote__footer">
                {%- if block.settings.publication_url != blank -%}
                  <a
                    href="{{ block.settings.publication_url }}"
                    class="press-quote__link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                {%- endif -%}
                  {%- if block.settings.publication_logo != blank -%}
                    <img
                      src="{{ block.settings.publication_logo | image_url: width: 200 }}"
                      alt="{{ block.settings.publication_name | escape }}"
                      class="press-quote__logo"
                      loading="lazy"
                      width="200"
                      height="60"
                    >
                  {%- elsif block.settings.publication_name != blank -%}
                    <cite class="press-quote__publication">{{ block.settings.publication_name }}</cite>
                  {%- endif -%}
                {%- if block.settings.publication_url != blank -%}
                  </a>
                {%- endif -%}
              </footer>
            {%- endif -%}
          </blockquote>
        {%- endfor -%}
      </div>

      <div class="press-epk__logo-wall">
        {%- for block in section.blocks -%}
          {%- if block.settings.publication_logo != blank -%}
            {%- if block.settings.publication_url != blank -%}
              <a
                href="{{ block.settings.publication_url }}"
                class="press-epk__logo-item"
                target="_blank"
                rel="noopener noreferrer"
              >
            {%- else -%}
              <div class="press-epk__logo-item">
            {%- endif -%}
              <img
                src="{{ block.settings.publication_logo | image_url: width: 150 }}"
                alt="{{ block.settings.publication_name | escape }}"
                loading="lazy"
                width="150"
                height="45"
              >
            {%- if block.settings.publication_url != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="press-epk__actions">
      {%- if section.settings.epk_download_url != blank and section.settings.epk_button_label != blank -%}
        <a
          href="{{ section.settings.epk_download_url }}"
          class="press-epk__download btn btn--accent"
          download
          target="_blank"
          rel="noopener noreferrer"
        >
          {{ section.settings.epk_button_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.press_contact_email != blank -%}
        <a
          href="mailto:{{ section.settings.press_contact_email }}"
          class="press-epk__contact btn btn--secondary"
        >
          Press contact
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{%- schema -%}
{
  "name": "Press & EPK",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Press",
      "info": "Main heading for the press section"
    },
    {
      "type": "header",
      "content": "EPK & Contact"
    },
    {
      "type": "url",
      "id": "epk_download_url",
      "label": "EPK download URL",
      "info": "Link to EPK PDF or press kit file"
    },
    {
      "type": "text",
      "id": "epk_button_label",
      "label": "EPK button text",
      "default": "Download EPK",
      "info": "Button text for EPK download"
    },
    {
      "type": "text",
      "id": "press_contact_email",
      "label": "Press contact email",
      "info": "Email address for press inquiries"
    },
    {
      "type": "paragraph",
      "content": "Bio excerpt is pulled from Artist Branding settings (artist_bio_short)"
    }
  ],
  "blocks": [
    {
      "type": "press_quote",
      "name": "Press quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote_text",
          "label": "Quote text",
          "default": "An incredible performance that captivates from start to finish.",
          "info": "Press quote or review excerpt"
        },
        {
          "type": "text",
          "id": "publication_name",
          "label": "Publication name",
          "default": "Music Magazine",
          "info": "Name of the publication or reviewer"
        },
        {
          "type": "image_picker",
          "id": "publication_logo",
          "label": "Publication logo",
          "info": "Logo image for the publication (optional, falls back to text)"
        },
        {
          "type": "url",
          "id": "publication_url",
          "label": "Publication URL",
          "info": "Link to the full article or publication website"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press & EPK",
      "settings": {
        "heading": "Press"
      },
      "blocks": [
        {
          "type": "press_quote",
          "settings": {
            "quote_text": "An incredible performance that captivates from start to finish.",
            "publication_name": "Music Magazine",
            "publication_url": ""
          }
        },
        {
          "type": "press_quote",
          "settings": {
            "quote_text": "A must-see live act with undeniable stage presence.",
            "publication_name": "Concert Review",
            "publication_url": ""
          }
        }
      ]
    }
  ]
}
{%- endschema -%}
