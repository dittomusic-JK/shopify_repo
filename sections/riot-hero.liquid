{%- comment -%}
  Riffride Riot — brutalist type-first hero.
  Unlike the standard image hero, the TYPE dominates: huge headline on the brand
  canvas, optional background media sits behind a heavy wash. Neon accent + dual
  CTAs. Distinct from musician-hero by design.
{%- endcomment -%}

{%- liquid
  assign sid = 'riot-hero-' | append: section.id
  assign min_h = section.settings.min_height | default: 88
-%}

<style>
  #{{ sid }} { position: relative; min-height: {{ min_h }}vh; display: flex; flex-direction: column; justify-content: flex-end; overflow: hidden; background: var(--brand-bg-0); color: var(--color-brand-primary); padding: clamp(1.5rem, 5vw, 4.5rem); }
  #{{ sid }} .riot-hero__media, #{{ sid }} .riot-hero__media img, #{{ sid }} .riot-hero__media video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  #{{ sid }} .riot-hero__wash { position: absolute; inset: 0; background: var(--brand-bg-0); opacity: {{ section.settings.media_wash | default: 55 | divided_by: 100.0 }}; }
  #{{ sid }} .riot-hero__inner { position: relative; z-index: 2; width: 100%; }
  #{{ sid }} .riot-hero__eyebrow { font-size: clamp(0.7rem, 1.4vw, 0.9rem); font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-brand-accent); margin: 0 0 1.25rem; }
  #{{ sid }} .riot-hero__headline { font-family: var(--font-heading); font-size: clamp(3.25rem, 15vw, 12rem); font-weight: 800; line-height: 0.82; letter-spacing: -0.03em; text-transform: uppercase; margin: 0; }
  #{{ sid }} .riot-hero__sub { font-size: clamp(0.95rem, 1.8vw, 1.25rem); font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-brand-secondary); margin: 1.5rem 0 0; max-width: 40ch; }
  #{{ sid }} .riot-hero__ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2.25rem; }
  #{{ sid }} .riot-hero__cta { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.95rem 1.75rem; text-decoration: none; display: inline-block; }
  #{{ sid }} .riot-hero__cta--primary { background: var(--color-brand-accent); color: var(--color-brand-on-accent); }
  #{{ sid }} .riot-hero__cta--secondary { background: transparent; color: var(--color-brand-primary); border: 1px solid var(--color-brand-primary); }
  #{{ sid }} .riot-hero__cta:hover { opacity: 0.88; }
</style>

<section id="{{ sid }}" class="riot-hero riot-reveal">
  {%- if section.settings.background_video != blank or section.settings.background_image != blank -%}
    <div class="riot-hero__media" aria-hidden="true">
      {%- if section.settings.background_video != blank -%}
        <video autoplay muted loop playsinline poster="{{ section.settings.background_image | image_url: width: 2400 }}">
          {%- for vsrc in section.settings.background_video.sources -%}{%- if vsrc.mime_type == "video/mp4" -%}<source src="{{ vsrc.url }}" type="{{ vsrc.mime_type }}">{%- endif -%}{%- endfor -%}
        </video>
      {%- elsif section.settings.background_image != blank -%}
        <img src="{{ section.settings.background_image | image_url: width: 2400 }}" alt="" loading="eager" fetchpriority="high" width="{{ section.settings.background_image.width }}" height="{{ section.settings.background_image.height }}">
      {%- endif -%}
    </div>
    <div class="riot-hero__wash"></div>
  {%- endif -%}

  <div class="riot-hero__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="riot-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.headline != blank -%}
      <h1 class="riot-hero__headline">{{ section.settings.headline }}{% if section.settings.show_neon_dot %}<span class="riot-dot">.</span>{% endif %}</h1>
    {%- endif -%}
    {%- if section.settings.subheadline != blank -%}
      <p class="riot-hero__sub">{{ section.settings.subheadline }}</p>
    {%- endif -%}
    {%- if section.settings.cta1_label != blank or section.settings.cta2_label != blank -%}
      <div class="riot-hero__ctas">
        {%- if section.settings.cta1_label != blank -%}
          <a class="riot-hero__cta riot-hero__cta--primary" href="{{ section.settings.cta1_url | default: '#' }}"{% if section.settings.cta1_url contains 'http' %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ section.settings.cta1_label }}</a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a class="riot-hero__cta riot-hero__cta--secondary" href="{{ section.settings.cta2_url | default: '#' }}"{% if section.settings.cta2_url contains 'http' %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ section.settings.cta2_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{%- schema -%}
{
  "name": "Riot hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Debut album" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "ARTIST NAME", "info": "Big brutalist display text." },
    { "type": "checkbox", "id": "show_neon_dot", "label": "Neon full-stop after headline", "default": true },
    { "type": "text", "id": "subheadline", "label": "Subheadline", "default": "New album — out now" },
    { "type": "text", "id": "cta1_label", "label": "Primary button text", "default": "Listen now" },
    { "type": "url", "id": "cta1_url", "label": "Primary button link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary button text", "default": "Shop merch" },
    { "type": "url", "id": "cta2_url", "label": "Secondary button link" },
    { "type": "header", "content": "Background (optional)" },
    { "type": "video", "id": "background_video", "label": "Background video", "info": "Optional. Type stays the focus; media sits behind a wash." },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "media_wash", "min": 0, "max": 90, "step": 5, "default": 55, "unit": "%", "label": "Background wash darkness" },
    { "type": "range", "id": "min_height", "min": 60, "max": 100, "step": 2, "default": 88, "unit": "vh", "label": "Hero height" }
  ],
  "presets": [
    {
      "name": "Riot hero",
      "settings": {
        "eyebrow": "Debut album",
        "headline": "ARTIST NAME",
        "subheadline": "New album — out now"
      }
    }
  ]
}
{%- endschema -%}
